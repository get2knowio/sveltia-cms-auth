# --- GitHub (primary path) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GITHUB_HOSTNAME=github.com        # override for GitHub Enterprise

# --- GitLab (parity; optional) ---
# GITLAB_CLIENT_ID=
# GITLAB_CLIENT_SECRET=
# GITLAB_HOSTNAME=gitlab.com

# Comma-separated allow-list for the CMS site_id (host). Supports a `*` wildcard,
# e.g. "*.example.com,localhost". Empty/unset allows any domain.
ALLOWED_DOMAINS=

# Where GET / redirects (the CMS admin page). Unset => GET / returns "sveltia-cms-auth OK".
CMS_ADMIN_URL=

# Server bind
PORT=3000
HOST=0.0.0.0
