{
  "name": "sveltia-cms-auth",
  "version": "1.0.0",
  "description": "OAuth broker for Sveltia/Decap CMS GitHub backends — a Bun port of sveltia/sveltia-cms-auth.",
  "license": "MIT",
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx --bun biome check .",
    "format": "bunx --bun biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.14",
    "typescript": "^6.0.3"
  }
}
